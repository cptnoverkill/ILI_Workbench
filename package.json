{
  "name": "ili-correlation-workbench",
  "version": "0.2.7",
  "description": "ILI Correlation Workbench \u2014 Pipeline Integrity Analysis",
  "main": "main.js",
  "author": {
    "name": "C-Squared",
    "email": "contact@c-squared.com"
  },
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac --universal",
    "build:linux": "electron-builder --linux --x64",
    "build:all": "electron-builder --win --mac --linux"
  },
  "devDependencies": {
    "electron": "^25.0.0",
    "electron-builder": "^23.6.0"
  },
  "build": {
    "appId": "com.csquared.ili-correlation-workbench",
    "productName": "ILI Correlation Workbench",
    "copyright": "\u00a9 2026 C-Squared",
    "files": [
      "main.js",
      "preload.js",
      "license.js",
      "index.html",
      "license-screen.html",
      "splash.html",
      "assets/**"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "createDesktopShortcut": true,
      "shortcutName": "ILI Correlation Workbench",
      "artifactName": "ILI_Correlation_Workbench_Setup.exe"
    },
    "publish": null
  }
}